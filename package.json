    "type": "git",
    "url": "git+https://github.com/lagie-marin/sql-connector.git"
  },
  "keywords": [
    "sql",
    "schema",
    "database",
    "orm",
    "model",
    "query",
    "connector",
    "mysql2",
    "sync",
    "migration",
    "builder",
    "pool",
    "mariadb",
    "rdbms"
  ],
  "author": "lagie-marin",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/lagie-marin/sql-connector/issues"
  },
  "homepage": "https://github.com/lagie-marin/sql-connector#readme",
  "private": false,
  "dependencies": {
    "@mlagie/logger": "1.0.2",
    "mysql2": "3.22.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-security": "^4.0.1"
  }
}
